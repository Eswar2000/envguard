{
  "name": "@eswar2000/envguard",
  "version": "0.2.0-dev",
  "description": "Type-safe environment variable validator with beautiful errors. Zero dependencies. Edge-runtime compatible.",
  "keywords": [
    "env",
    "environment",
    "validation",
    "config",
    "typescript",
    "dotenv",
    "edge"
  ],
  "license": "MIT",
  "author": "Eswar2000",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eswar2000/envguard.git"
  },
  "bugs": {
    "url": "https://github.com/Eswar2000/envguard/issues"
  },
  "homepage": "https://github.com/Eswar2000/envguard#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "envguard": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "example": "tsx examples/basic.ts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
